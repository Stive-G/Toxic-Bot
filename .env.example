# Copy this file to .env, then replace every placeholder before deployment.

# Discord
DISCORD_TOKEN=replace_with_your_discord_bot_token
CLIENT_ID=replace_with_your_discord_application_id
GUILD_ID=replace_with_your_discord_guild_id
OWNER_IDS=replace_with_your_discord_user_id
MULTI_GUILD=false
PREFIX=!

# Runtime and web health endpoint
NODE_ENV=production
LOG_LEVEL=warn
LOG_TO_FILE=false
PORT=3000
WEB_HOST=0.0.0.0
PORT_RETRY_ATTEMPTS=5
# Set to your dashboard origin when one is configured; do not use * in production.
CORS_ORIGIN=https://your-dashboard.example.com

# PostgreSQL
POSTGRES_URL=postgresql://toxicbot:replace_with_a_strong_password@localhost:5432/toxicbot
POSTGRES_SSL=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=toxicbot
POSTGRES_USER=toxicbot
POSTGRES_PASSWORD=replace_with_a_strong_password
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_MIN_CONNECTIONS=2
POSTGRES_CONNECTION_TIMEOUT=10000
POSTGRES_IDLE_TIMEOUT=30000
POSTGRES_RETRIES=3
POSTGRES_BACKOFF_BASE=100
POSTGRES_BACKOFF_MULTIPLIER=2

# Migrations and backups
AUTO_MIGRATE=true
POSTGRES_MIGRATION_TABLE=schema_migrations
SCHEMA_VERSION=1
SCHEMA_VERSION_LABEL=baseline-v1
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
POSTGRES_RESTORE_URL=

# Lavalink v4
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=replace_with_a_unique_lavalink_password
LAVALINK_SECURE=false
LAVALINK_NAME=Main
LAVALINK_SEARCH_PLATFORM=ytmsearch
LAVALINK_REST_VERSION=v4

# Optional feature/API keys
TMDB_API_KEY=
